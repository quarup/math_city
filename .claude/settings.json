{
  "permissions": {
    "allow": [
      "Bash(python3 -c ' *)",
      "Bash(ls *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f; case \"$f\" in *.dart) dart format \"$f\" >/dev/null 2>&1 || true ;; esac; }"
          }
        ]
      }
    ]
  }
}
